# https://node-tap.org/cli/#configuration

files:
  - tests/tap/*.js

coverage-report:
  - text

reporter: terse
browser: true
color: true

branches: 100
functions: 100
lines: 100
statements: 100

# jobs: 3
timeout: 30

snapshot-clean-cwd: true

allow-empty-coverage: true
allow-incomplete-coverage: true
